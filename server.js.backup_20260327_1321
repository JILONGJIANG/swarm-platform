const http = require('http');
const ERP_BASE = 'http://localhost:3020/apiData';

function proxyERP(path, req, res) {
  const url = ERP_BASE + path;
  const method = req.method || 'GET';
  let body = '';
  req.on('data', d => body += d);
  req.on('end', () => {
    const options = {
      method,
      headers: { 'Content-Type': 'application/json' }
    };
    const proxyReq = http.request(url, options, proxyRes => {
      res.status(proxyRes.statusCode);
      proxyRes.pipe(res);
    });
    proxyReq.on('error', () => res.status(502).json({error:'ERP unavailable'}));
    if (body) proxyReq.write(body);
    proxyReq.end();
  });
}

